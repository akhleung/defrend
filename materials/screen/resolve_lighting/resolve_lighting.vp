#version 420 core

uniform lighting_vp {
	mat4 mtx_viewproj;
	mat4 mtx_view;
	vec4 directional_to;
};

// positions are in world space
in vec4 position;
in vec2 texcoord0;

out vec2 var_texcoord0;
out vec3 directional_from;

void main() {
	gl_Position			= mtx_viewproj * vec4(position.xyz, 1.0);
	var_texcoord0		= texcoord0;
	directional_from	= normalize(mat3(mtx_view) * -directional_to.xyz);
}
