#version 420 core

in vec4 position;
in vec3 normal;
in mat4 mtx_world;
in mat4 mtx_normal;

uniform shadow_vp {
	mat4 mtx_view;
	mat4 mtx_proj;
    vec4 bias;
};

void main() {
	vec3 vn = normalize((mtx_normal * vec4(normal, 0.0)).xyz);
	vec4 vp = mtx_view * mtx_world * position;
	vp.xyz -= bias.x * vn;
	gl_Position = mtx_proj * vp;
}
