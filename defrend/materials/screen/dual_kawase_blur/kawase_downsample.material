name: "dual_kawase_blur_downsample"
tags: "screen"
vertex_program: "/defrend/materials/screen/screen.vp"
fragment_program: "/defrend/materials/screen/dual_kawase_blur/kawase_downsample.fp"
vertex_constants {
  name: "mtx_viewproj"
  type: CONSTANT_TYPE_VIEWPROJ
}
samplers {
  name: "color_sampler"
  wrap_u: WRAP_MODE_CLAMP_TO_EDGE
  wrap_v: WRAP_MODE_CLAMP_TO_EDGE
  filter_min: FILTER_MODE_MIN_LINEAR
  filter_mag: FILTER_MODE_MAG_LINEAR
  max_anisotropy: 0.0
}
