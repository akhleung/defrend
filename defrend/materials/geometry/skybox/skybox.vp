#version 420 core

in vec4 position;

uniform skybox_vp {
    mat4 mtx_view;
    mat4 mtx_proj;
};

out vec3 var_texcoord0;

void main() {
	var_texcoord0 = position.xyz;
    #ifndef EDITOR
    gl_Position = (mtx_proj * mat4(mat3(mtx_view)) * position).xyww; // rotate only, and clamp to the far plane
    #else
    gl_Position = mtx_proj * mtx_view * position;
    #endif
}
