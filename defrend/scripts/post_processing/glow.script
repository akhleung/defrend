local settings = require "defrend.render.settings"
local uniforms = require "defrend.render.uniforms"

go.property("enabled", true)
go.property("radius", 4)
go.property("separation", 1)

function init(self)
	settings.glow.enabled = self.enabled
	settings.glow.radius = self.radius
	settings.glow.separation = self.separation
	uniforms.glow.init()
end
