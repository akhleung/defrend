local settings = require "defrend.render.settings"
local uniforms = require "defrend.render.uniforms"

go.property("enabled", false)
go.property("samples", 1)

function init(self)
	settings.kuwahara_blur.enabled = self.enabled
	settings.kuwahara_blur.samples = self.samples
	uniforms.kuwahara_blur.init()
end
