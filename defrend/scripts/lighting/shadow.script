local settings = require "defrend.render.settings"
local uniforms = require "defrend.render.uniforms"
local shadows = require "defrend.render.shadows"

local MSG_REFRESH = hash("refresh")

go.property("enabled", true)
go.property("stable_shadows", true)
go.property("cascade", vmath.vector4(0.20, 0.10, 0.10, 0.20))
go.property("biases", vmath.vector4(0.5, 0.75, 0.75, 1.2))
go.property("cascade_transition_range", 10)
go.property("atlas_resolution", 4096)
go.property("light_frustum_z_padding", 0.5)
go.property("pcf_samples", 8)
go.property("poisson_disc_samples", 4)
go.property("poisson_scale", 3000)
go.property("soft_penumbras", true)

local function do_init(self)
	settings.shadow.enabled = self.enabled
	settings.shadow.stable = self.stable_shadows
	if settings.shadow.stable then
		shadows.refresh_shadows = shadows.refresh_shadows_stable
	else
		shadows.refresh_shadows = shadows.refresh_shadows_half_stable
	end

	local cascade	= { self.cascade.x, self.cascade.y, self.cascade.z, self.cascade.w }
	local biases	= { self.biases.x, self.biases.y, self.biases.z, self.biases.w }
	settings.shadow.cascade	= {}
	settings.shadow.biases	= {}
	if settings.shadow.enabled then
		for i = 1, #cascade do
			-- stop adding partitions to the cascade when a size of 0 is encountered
			if cascade[i] == 0 then break end
			settings.shadow.cascade[i] = cascade[i]
			settings.shadow.biases[i] = biases[i]
		end
		if #settings.shadow.cascade == 0 then
			settings.shadow.enabled = false
		end
	end

	settings.shadow.transition_range	= self.cascade_transition_range
	settings.shadow.atlas_resolution	= self.atlas_resolution
	settings.shadow.z_padding_factor	= self.light_frustum_z_padding
	settings.shadow.pcf_samples			= self.pcf_samples
	settings.shadow.poisson_samples		= self.poisson_disc_samples
	settings.shadow.poisson_scale		= self.poisson_scale
	settings.shadow.soft_penumbras		= self.soft_penumbras

    uniforms.shadow.init()
end

function init(self)
	-- wait for the camera config script to send a refresh message to this script since we can't fully initialize
	-- shadows without the camera frustum
end

function on_message(self, message_id, message, sender)
	if message_id == MSG_REFRESH and settings.scene_camera_url then
		do_init(self)
	end
end

function on_reload(self)
	do_init(self)
end
